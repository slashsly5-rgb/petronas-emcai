        else:
            return self._get_sample_logs()

    def get_tools(self, filters: Optional[Dict] = None) -> pd.DataFrame:
        """Fetch tool tracking records"""
        result = self._make_request("GET", config.ENDPOINTS["tools"]["list"])

        if result is None:
            return self._get_sample_tools()

        if isinstance(result, list):
