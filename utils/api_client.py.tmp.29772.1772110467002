"""API Client for n8n webhook integration"""
import requests
import pandas as pd
from typing import Dict, List, Optional
from datetime import datetime
import config

class N8NClient:
    """Client for interacting with n8n webhooks"""

    def __init__(self):
        self.timeout = 10
        self.max_retries = 3

    def _make_request(self, method: str, url: str, data: Optional[Dict] = None) -> Optional[Dict]:
        """Make HTTP request with retry logic"""
        for attempt in range(self.max_retries):
            try:
                if method == "GET":
                    response = requests.get(url, timeout=self.timeout)
                elif method == "POST":
                    response = requests.post(url, json=data, timeout=self.timeout)
                elif method == "PUT":
                    response = requests.put(url, json=data, timeout=self.timeout)
                elif method == "DELETE":
                    response = requests.delete(url, timeout=self.timeout)

                response.raise_for_status()
                return response.json() if response.text else {}
            except requests.exceptions.RequestException as e:
                if attempt == self.max_retries - 1:
                    print(f"Request failed after {self.max_retries} attempts: {e}")
                    return None
        return None

    def get_components(self, filters: Optional[Dict] = None) -> pd.DataFrame:
        """Fetch component inventory"""
        result = self._make_request("GET", config.ENDPOINTS["components"]["list"])

        if result is None:
            # Return sample data for demo if n8n is not available
            return self._get_sample_components()

        # Convert to DataFrame
        if isinstance(result, list):
            return pd.DataFrame(result)
        elif isinstance(result, dict) and "data" in result:
            return pd.DataFrame(result["data"])
        else:
            return self._get_sample_components()

    def get_logs(self, filters: Optional[Dict] = None) -> pd.DataFrame:
        """Fetch maintenance logs"""
        result = self._make_request("GET", config.ENDPOINTS["logs"]["list"])

        if result is None:
